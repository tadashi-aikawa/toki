layout {
  pane {
    pane split_direction="vertical" {
      pane name=" Neovim" size="60%" command="nvim" {
        cwd "~/git/github.com/tadashi-aikawa/copilot-plugin-notify/"
      } 

      pane {
        pane name="Install" size="5" {
          cwd     "~/git/github.com/tadashi-aikawa/"
          command "copilot"
          args "plugin" "install" "./copilot-plugin-notify"
        }
        pane name="Event Log" {
          cwd     "/tmp"
          command "zsh"
          args    "-c" "tail -F copilot-notify.jsonl | while IFS= read -r line; do jq -e . >/dev/null 2>&1 <<<\"$line\" && jq . <<<\"$line\" || printf '%s\n' \"$line\"; done"
        }
      }
    }
  }  
}
